#!/usr/bin/env bash
set -uo pipefail

VERSION="0.2.0"
MAX_CONSECUTIVE_TIMEOUTS=2
FORCE_PROTO=""

# ---------------------------------------------------------------------------
# Colors (respect NO_COLOR env var and non-TTY output)
# ---------------------------------------------------------------------------
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  CYAN=$'\033[0;36m'
  YELLOW=$'\033[1;33m'
  GREEN=$'\033[0;32m'
  RED=$'\033[0;31m'
  RESET=$'\033[0m'
else
  BOLD='' DIM='' CYAN='' YELLOW='' GREEN='' RED='' RESET=''
fi

# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------
die() {
  printf "%sError:%s %s\n" "$RED" "$RESET" "$1" >&2
  exit 1
}

usage() {
  cat <<EOF
Usage: tracegeo [options] <destination>

Trace the route to a destination and show geolocation for each hop.

Options:
  -h, --help       Show this help message
  -v, --version    Show version
  -m, --max-hops N Maximum number of hops (default: 30)
  -q, --queries N  Number of probes per hop (default: 3)
  -4               Force IPv4
  -6               Force IPv6
  -t, --timeout N  Give up after N consecutive timeouts (default: 2)

Examples:
  tracegeo google.com
  tracegeo -m 15 example.com
  tracegeo -6 google.com
  tracegeo 2001:4860:4860::8888
  tracegeo https://google.com/imghp?hl=en&ogbl
EOF
}

check_deps() {
  local missing=()
  for cmd in dig traceroute curl; do
    command -v "$cmd" &>/dev/null || missing+=("$cmd")
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    die "Missing required commands: ${missing[*]}"
  fi
}

is_ipv4() {
  [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]
}

is_ipv6() {
  [[ "$1" == *:* ]]
}

is_private_ip() {
  case "$1" in
    # IPv4 private/reserved
    10.*|172.1[6-9].*|172.2[0-9].*|172.3[0-1].*|192.168.*|169.254.*|127.*) return 0 ;;
    # IPv6 loopback
    ::1) return 0 ;;
    # IPv6 link-local (fe80::/10)
    fe8[0-9a-fA-F]:*|fe9[0-9a-fA-F]:*|fea[0-9a-fA-F]:*|feb[0-9a-fA-F]:*) return 0 ;;
    # IPv6 unique local (fc00::/7)
    fc[0-9a-fA-F][0-9a-fA-F]:*|fd[0-9a-fA-F][0-9a-fA-F]:*) return 0 ;;
    *) return 1 ;;
  esac
}

parse_target() {
  local t="$1"
  local had_scheme=false
  # Strip scheme (e.g. https://, http://)
  if [[ "$t" == *"://"* ]]; then
    t="${t#*://}"
    had_scheme=true
  fi
  # Strip path, query, fragment
  t="${t%%/*}"
  t="${t%%\?*}"
  t="${t%%#*}"
  # Strip port only if a scheme was present (bare IPv6 addresses contain colons)
  if $had_scheme; then
    if [[ "$t" == "["* ]]; then
      # IPv6 in brackets: [::1]:8080 → ::1
      t="${t#\[}"
      t="${t%%\]*}"
    else
      t="${t%%:*}"
    fi
  fi
  echo "$t"
}

resolve_traceroute_cmd() {
  local proto="$1"
  if [[ "$proto" == "6" ]]; then
    if command -v traceroute6 &>/dev/null; then
      echo "traceroute6"
    elif traceroute -6 ::1 &>/dev/null 2>&1; then
      echo "traceroute -6"
    else
      die "IPv6 traceroute not available. Install traceroute6 or a traceroute with -6 support."
    fi
  else
    echo "traceroute"
  fi
}

# ---------------------------------------------------------------------------
# Spinner (background subprocess, writes to stderr only)
# ---------------------------------------------------------------------------
SPINNER_PID=""

start_spinner() {
  [[ ! -t 2 ]] && return
  local label="$1"
  (
    frames=('|' '/' '-' '\')
    i=0
    while true; do
      printf "\r  %s %s" "${frames[$((i % 4))]}" "$label" >&2
      ((i++))
      sleep 0.1
    done
  ) &
  SPINNER_PID=$!
}

stop_spinner() {
  if [[ -n "$SPINNER_PID" ]]; then
    kill "$SPINNER_PID" 2>/dev/null
    wait "$SPINNER_PID" 2>/dev/null || true
    SPINNER_PID=""
    printf "\r\033[K" >&2
  fi
}

_CLEANING_UP=false

cleanup() {
  $_CLEANING_UP && return
  _CLEANING_UP=true
  stop_spinner
  kill 0 2>/dev/null || true
}

trap cleanup EXIT
trap 'cleanup; exit 130' INT
trap 'cleanup; exit 143' TERM

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
MAX_HOPS=30
PROBES=3

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)     usage; exit 0 ;;
    -v|--version)  echo "tracegeo $VERSION"; exit 0 ;;
    -m|--max-hops) MAX_HOPS="$2"; shift ;;
    -q|--queries)  PROBES="$2"; shift ;;
    -4)            FORCE_PROTO="4" ;;
    -6)            FORCE_PROTO="6" ;;
    -t|--timeout)  MAX_CONSECUTIVE_TIMEOUTS="$2"; shift ;;
    --)            shift; break ;;
    -*)            die "Unknown option: $1" ;;
    *)             break ;;
  esac
  shift
done

TARGET="${1:-}"
[[ -z "$TARGET" ]] && { usage; exit 1; }
TARGET=$(parse_target "$TARGET")

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
check_deps

# Resolve target and determine protocol
if is_ipv4 "$TARGET"; then
  target_ip="$TARGET"
  proto="4"
elif is_ipv6 "$TARGET"; then
  target_ip="$TARGET"
  proto="6"
else
  # Hostname — resolve according to FORCE_PROTO
  if [[ "$FORCE_PROTO" == "6" ]]; then
    target_ip=$(dig +short AAAA "$TARGET" | grep -iE "^[0-9a-f]*:" | head -1)
    [[ -z "$target_ip" ]] && die "Could not resolve $TARGET to an IPv6 address"
    proto="6"
  elif [[ "$FORCE_PROTO" == "4" ]]; then
    target_ip=$(dig +short A "$TARGET" | grep -E "^[0-9]" | head -1)
    [[ -z "$target_ip" ]] && die "Could not resolve $TARGET to an IPv4 address"
    proto="4"
  else
    # Auto-detect: try A first (backward compat), fall back to AAAA
    target_ip=$(dig +short A "$TARGET" | grep -E "^[0-9]" | head -1)
    if [[ -n "$target_ip" ]]; then
      proto="4"
    else
      target_ip=$(dig +short AAAA "$TARGET" | grep -iE "^[0-9a-f]*:" | head -1)
      if [[ -n "$target_ip" ]]; then
        proto="6"
      else
        die "Could not resolve $TARGET"
      fi
    fi
  fi
fi

# Validate: don't allow protocol mismatch with raw IP
if [[ "$FORCE_PROTO" == "6" ]] && is_ipv4 "$target_ip"; then
  die "Cannot use -6 with IPv4 address $target_ip"
fi
if [[ "$FORCE_PROTO" == "4" ]] && is_ipv6 "$target_ip"; then
  die "Cannot use -4 with IPv6 address $target_ip"
fi

# Resolve the traceroute command for this protocol
TRACEROUTE_CMD=$(resolve_traceroute_cmd "$proto")

# Set column width based on protocol
if [[ "$proto" == "6" ]]; then
  IP_WIDTH=40
  IP_DASHES="────────────────────────────────────────"
else
  IP_WIDTH=16
  IP_DASHES="────────────────"
fi

# Header
if [[ "$TARGET" == "$target_ip" ]]; then
  printf "Tracing route to %s%s%s...\n\n" "$BOLD" "$target_ip" "$RESET"
else
  printf "Tracing route to %s%s%s (%s%s%s)...\n\n" \
    "$BOLD" "$TARGET" "$RESET" "$CYAN" "$target_ip" "$RESET"
fi

# Table header
printf " %s%-4s  %-${IP_WIDTH}s  %10s  %10s   %-24s %s%s\n" \
  "$DIM" "HOP" "IP" "LATENCY" "DELTA" "LOCATION" "ORG" "$RESET"
printf " %s%-4s  %-${IP_WIDTH}s  %10s  %10s   %-24s %s%s\n" \
  "$DIM" "───" "$IP_DASHES" "──────────" "──────────" "────────────────────────" "────────────────────" "$RESET"

# Traceroute + geo lookup
hop_count=0
reached=false
timed_out=false
consecutive_timeouts=0
prev_latency_ms=""

while IFS= read -r -t 30 line; do
  # Skip traceroute header line
  [[ "$line" == traceroute* ]] && continue

  # Extract hop number
  hop=$(echo "$line" | awk '{print $1}')
  [[ -z "$hop" || ! "$hop" =~ ^[0-9]+$ ]] && continue
  hop_count=$hop

  # Timeout line (* * *)
  if [[ "$line" =~ ^[[:space:]]*[0-9]+[[:space:]]+\*[[:space:]]+\*[[:space:]]+\* ]]; then
    printf " %s%3s%s  %s%-${IP_WIDTH}s%s  %s%10s%s  %s%10s%s   %s%-24s%s %s%s%s\n" \
      "$BOLD" "$hop" "$RESET" \
      "$DIM" "*" "$RESET" \
      "$DIM" "*" "$RESET" \
      "$DIM" "-" "$RESET" \
      "$DIM" "-" "$RESET" \
      "$DIM" "-" "$RESET"
    prev_latency_ms=""
    ((consecutive_timeouts++)) || true
    if [[ $consecutive_timeouts -ge $MAX_CONSECUTIVE_TIMEOUTS ]]; then
      timed_out=true
      break
    fi
    continue
  fi

  consecutive_timeouts=0

  # Extract IP and latency
  if [[ "$proto" == "6" ]]; then
    ip=$(echo "$line" | grep -oE '[0-9a-fA-F:]+:[0-9a-fA-F:]+' | head -1)
  else
    ip=$(echo "$line" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -1)
  fi
  latency=$(echo "$line" | grep -oE '[0-9]+\.[0-9]+ ms' | head -1)
  latency="${latency:--}"

  # Compute delta from previous hop
  cur_ms="${latency% ms}"
  if [[ "$cur_ms" =~ ^[0-9]+\.[0-9]+$ ]] && [[ -n "$prev_latency_ms" ]]; then
    delta=$(awk "BEGIN {d = $cur_ms - $prev_latency_ms; printf \"%+.1f ms\", d}")
  else
    delta="-"
  fi
  if [[ "$cur_ms" =~ ^[0-9]+\.[0-9]+$ ]]; then
    prev_latency_ms="$cur_ms"
  else
    prev_latency_ms=""
  fi

  [[ -z "$ip" ]] && continue

  [[ "$ip" == "$target_ip" ]] && reached=true

  # Private IP — skip geo lookup
  if is_private_ip "$ip"; then
    printf " %s%3s%s  %s%-${IP_WIDTH}s%s  %s%10s%s  %s%10s%s   %s%-24s%s %s%s%s\n" \
      "$BOLD" "$hop" "$RESET" \
      "$CYAN" "$ip" "$RESET" \
      "$YELLOW" "$latency" "$RESET" \
      "$YELLOW" "$delta" "$RESET" \
      "$DIM" "(private)" "$RESET" \
      "$DIM" "-" "$RESET"
    continue
  fi

  # Geo lookup
  start_spinner "Looking up $ip..."

  response=$(curl -s -m 3 -w "\n%{http_code}" "https://ipinfo.io/$ip" 2>/dev/null) || true
  http_code=$(echo "$response" | tail -1)
  body=$(echo "$response" | sed '$d')

  stop_spinner

  if [[ "$http_code" == "200" ]]; then
    city=$(echo "$body" | grep -o '"city": *"[^"]*"' | cut -d'"' -f4)
    country=$(echo "$body" | grep -o '"country": *"[^"]*"' | cut -d'"' -f4)
    org=$(echo "$body" | grep -o '"org": *"[^"]*"' | cut -d'"' -f4)

    if [[ -n "$city" && -n "$country" ]]; then
      location="$city, $country"
    elif [[ -n "$country" ]]; then
      location="$country"
    else
      location="-"
    fi
    org="${org:--}"
  else
    location="(lookup failed)"
    org="-"
  fi

  printf " %s%3s%s  %s%-${IP_WIDTH}s%s  %s%10s%s  %s%10s%s   %s%-24s%s %s%s%s\n" \
    "$BOLD" "$hop" "$RESET" \
    "$CYAN" "$ip" "$RESET" \
    "$YELLOW" "$latency" "$RESET" \
    "$YELLOW" "$delta" "$RESET" \
    "$GREEN" "$location" "$RESET" \
    "$DIM" "$org" "$RESET"

done < <($TRACEROUTE_CMD -n -m "$MAX_HOPS" -q "$PROBES" "$target_ip" 2>&1)

# Footer
echo
if [[ $hop_count -eq 0 ]]; then
  die "No hops recorded. You may need to run with sudo."
elif $reached; then
  printf "Done. %s%d hops%s, destination reached.\n" "$GREEN" "$hop_count" "$RESET"
elif $timed_out; then
  printf "Done. %s%d hops%s, last %d hops did not respond.\n" "$YELLOW" "$hop_count" "$RESET" "$consecutive_timeouts"
else
  printf "Done. %s%d hops%s, destination not reached.\n" "$YELLOW" "$hop_count" "$RESET"
fi
